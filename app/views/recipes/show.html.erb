<div class="card w-full max-w-3xl bg-base-100 shadow-xl overflow-y-auto max-h-[80vh]">
  <div class="card-body">
    <div class="flex items-center justify-between mb-4">
      <h1 class="items-start text-2xl font-bold mb-2"><%= @recipe.title %></h1>

      <div class="flex float-right gap-4 mb-4">
        <span class="badge badge-info">Prep: <%= @recipe.prep_time %> min</span>
        <span class="badge badge-success">Cook: <%= @recipe.cook_time %> min</span>
      </div>
    </div>

    <div class="flex flex-row">
      <div id="recipe-categories" class="flex-1" data-controller="recipe-categories" data-recipe-id="<%= @recipe.id %>">
        <%= render partial: "ingredients/loading_placeholder", locals: { recipe: @recipe } %>
      </div>

      <div id="recipe-tags" class="flex-1" data-controller="recipe-tags" data-recipe-id="<%= @recipe.id %>">
        <%= render partial: "ingredients/loading_placeholder", locals: { recipe: @recipe } %>
      </div>
    </div>

    <p class="mb-4"><%= @recipe.description %></p>

    <div class="flex flex-row">
      <div class="flex-1">
        <h3 class="text-xl font-semibold mb-2">Ingredients</h3>
        <div id="recipe-ingredients" data-controller="recipe-ingredients" data-recipe-id="<%= @recipe.id %>" data-recipe-ingredients-recipe-id="<%= @recipe.id %>">
          <%= render partial: "ingredients/loading_placeholder", locals: { recipe: @recipe } %>
        </div>
      </div>

      <div class="flex-1">
        <h3 class="text-xl font-semibold mb-2">Instructions</h3>
        <p><%= simple_format(@recipe.instructions) %></p>
      </div>
    </div>

    <!-- Comments Form -->
    <% if user_signed_in? %>
      <div class="mb-6">
        <%= render partial: "comments/form", locals: { recipe: @recipe, comment: @recipe.comments.new } %>
      </div>
    <% end %>
    
    <!-- Comments List -->
    <%= turbo_stream_from "comments" %>
    <div id="comments" class="space-y-4">
      <% if @recipe.comments.any? %>
        <%= render @recipe.comments.order(created_at: :desc) %>
      <% else %>
        <p class="text-sm text-gray-500">No comments yet. Be the first to comment!</p>
      <% end %>
    </div>

    <% if current_user.id == @recipe.user_id %>
      <div class="card-actions justify-end">
        <%= link_to "Edit", edit_recipe_path(@recipe), class: "btn btn-sm btn-outline", data: { turbo: false } %>
        <%= link_to "Delete", recipe_path(@recipe), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-error" %>
      </div>
    <% end %>
    <%= link_to "Back", recipes_path, class: "btn btn-primary btn-sm" %>
  </div>
</div>
