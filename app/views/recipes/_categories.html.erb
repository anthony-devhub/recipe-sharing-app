<h3 class="text-xl font-semibold mb-2 mt-4">Categories</h3>
<% cache ["recipe-categories", @recipe.cache_key_with_version] do %>
  <div class="flex flex-wrap gap-2 mb-4">
    <% recipe.categories.each do |category| %>
      <span class="badge badge-primary"><%= category.name %></span>
    <% end %>
  </div>
<% end %>