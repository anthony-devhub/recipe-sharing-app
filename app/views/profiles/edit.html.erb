<div class="max-w-xl mx-auto mt-2 p-6 bg-base-100 rounded shadow">
  <h1 class="text-3xl font-semibold mb-6">Edit Your Profile</h1>

  <%= form_with(model: @user, url: profile_path, method: :patch, local: true, class: "space-y-6") do |form| %>
    <div>
      <%= form.label :username, class: "block font-medium mb-1" %>
      <%= form.text_field :username, class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :bio, class: "block font-medium mb-1" %>
      <%= form.text_area :bio, rows: 4, class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :phone_number, class: "block font-medium mb-1" %>
      <%= form.telephone_field :phone_number, class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.submit "Save Changes", class: "px-6 py-2 bg-green-600 text-white rounded hover:bg-green-700" %>
      <%= link_to 'Cancel', profile_path, class: "ml-4 text-gray-600 hover:underline" %>
    </div>
  <% end %>
</div>
