<div class="max-w-xl mx-auto mt-2 p-6 rounded shadow">
  <div class="card w-full max-w-md shadow-xl bg-base-100">
    <div class="card-body">
      <h2 class="card-title">Sign In</h2>
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="form-control">
          <%= f.label :email, class: "label" %>
          <%= f.email_field :email, autofocus: true, class: "input input-bordered" %>
        </div>
        
        <div class="form-control mt-4">
          <%= f.label :password, class: "label" %>
          <%= f.password_field :password, class: "input input-bordered" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="form-control mt-4">
            <%= f.check_box :remember_me %>
            <%= f.label :remember_me %>
          </div>
        <% end %>

        <div class="form-control mt-6">
          <%= f.submit "Log in", class: "btn btn-primary w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</div>