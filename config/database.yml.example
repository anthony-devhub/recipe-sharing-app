default: &default
  adapter: postgresql
  encoding: unicode
  username: postgres
  password: postgres
  host: localhost
  port: 5432
  pool: <%= ENV.fetch("RAILS_MAX_THREADS") { 5 } %>


development:
  primary: &primary_development
    <<: *default
    database: recipe_sharing_app_development
  cache:
    <<: *primary_development
    database: recipe_sharing_app_development_cache
    migrations_paths: db/cache_migrate
  cable:
    <<: *primary_development
    database: recipe_sharing_app_development_cable
    migrations_paths: db/cable_migrate
  queue:
    <<: *primary_development
    database: recipe_sharing_app_development_queue
    migrations_paths: db/queue_migrate

test:
  primary: &primary_test
    <<: *default
    database: recipe_sharing_app_test
  cache:
    <<: *primary_test
    database: recipe_sharing_app_test_cache
    migrations_paths: db/cache_migrate
  cable:
    <<: *primary_test
    database: recipe_sharing_app_test_cable
    migrations_paths: db/cable_migrate
  queue:
    <<: *primary_test
    database: recipe_sharing_app_test_queue
    migrations_paths: db/queue_migrate

production:
  primary: &primary_production
    <<: *default
    database: recipe_sharing_app_production
    username: recipe_sharing_app
    password: <%= ENV["RECIPE_SHARING_APP_DATABASE_PASSWORD"] %>
  cache:
    <<: *primary_production
    database: recipe_sharing_app_production_cache
    migrations_paths: db/cache_migrate
  queue:
    <<: *primary_production
    database: recipe_sharing_app_production_queue
    migrations_paths: db/queue_migrate
  cable:
    <<: *primary_production
    database: recipe_sharing_app_production_cable
    migrations_paths: db/cable_migrate
